{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:webview:deny-internal-toggle-devtools",
    "dialog:default",
    "fs:default",
    "fs:allow-appcache-read-recursive",
    "fs:allow-appcache-write-recursive"
  ]
}
